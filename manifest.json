{
  "manifest_version": 3,
  "name": "Looker Studio CSS Tweaker",
  "version": "1.0",
  "description": "Toggle and adjust custom CSS in Google Looker Studio editor.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://lookerstudio.google.com/*", "https://datastudio.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": ["https://lookerstudio.google.com/*", "https://datastudio.google.com/*"]
}
